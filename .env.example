# ── Production Environment Configuration (Render) ──
# You will add these variables to your Render Web Service -> Environment Variables tab.

# Database (From Aiven)
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=20387  # Check Aiven for your specific port
DB_USER=avnadmin
DB_PASSWORD=your_aiven_password
DB_NAME=defaultdb

# JWT Security
JWT_SECRET_KEY=generate_a_long_random_string_here

# Flask
FLASK_ENV=production
FLASK_DEBUG=0
