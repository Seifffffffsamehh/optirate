# ── Production Environment Configuration (Render + Aiven) ──
# Set these in Render Dashboard → optirate → Environment

# Database (Aiven Free MySQL)
DB_HOST=your-host.a.aivencloud.com
DB_PORT=20387
DB_USER=avnadmin
DB_PASSWORD=your_aiven_password
DB_NAME=defaultdb
DB_SSL=true

# JWT Security (Render can auto-generate via render.yaml)
JWT_SECRET_KEY=generate_a_long_random_string_here

# Flask
FLASK_ENV=production
FLASK_DEBUG=0

# Optional: only if frontend is hosted on a different domain
# CORS_ORIGINS=https://your-frontend.example.com
